# SmartKhata API — copy to .env (never commit .env)

PORT=5000
NODE_ENV=development

MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/smartkhata?retryWrites=true&w=majority

# Minimum 32 characters in production
JWT_SECRET=change-me-use-long-random-secret-in-production-at-least-32-chars
JWT_EXPIRES_IN=7d

# Production: your Vercel site origin(s), comma-separated for multiple (e.g. preview + prod)
# Development: optional extra origins; localhost is always allowed for dev
FRONTEND_URL=http://localhost:5173

# Legacy alias — prefer FRONTEND_URL
# CORS_ORIGIN=http://localhost:5173

# Uploads live under process.cwd() / UPLOAD_DIR
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
RESTORE_MAX_BYTES=54525952

JSON_BODY_LIMIT=1mb

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=400
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Set false to disable DB audit writes (login, transactions, restore)
AUDIT_LOG_ENABLED=true
